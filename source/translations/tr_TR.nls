    <fDictEditForm Caption="Sözlük Güncelleyici">
      <pTop>
        <cbLocale Hint="Sözlüğe eklenecek kelimeler için yerel ayar."/>
        <lbLocale Hint="Sözlüğe eklenecek kelimeler için yerel ayarı seçin." Caption="Yerel Ayar:"/>
        <btnInvert Hint="Tüm seçimleri tersine çevir." Caption="Tersine Çevir"/>
        <btnNone Hint="Tüm kelimelerin seçimini kaldır." Caption="Hiçbiri"/>
      </pTop>
      <pButtons>
        <btnSave Hint="Sözlükteki değişiklikleri kaydet." Caption="Kaydet"/>
        <btnReload Hint="Sözlüğü yeniden yükle ve kaydedilmemiş değişiklikleri unut." Caption="Yeniden Yükle"/>
        <btnAdd Hint="Seçili kelimeleri seçili yerel ayar için sözlüğe ekle." Caption="Sözlüğe Ekle"/>
        <btnMerge Hint="Kullanıcı sözlüğü kelimelerini Ana sözlükle birleştir." Caption="Birleştir"/>
      </pButtons>
    </fDictEditForm>
    <fOptionsDialog Caption="Codepage Witch Tercihleri">
      <pPages>
        <tsAbout Hint="Bu uygulama hakkında." Caption="Hakkında">
          <lbCopyright Caption="Telif Hakkı %s"/>
          <lbVersion Caption="Sürüm %0:s (derleme %1:s)"/>
          <lbApplication Caption="&quot;%s&quot;"/>
        </tsAbout>
        <tsGeneral Hint="Genel uygulama ayarları." Caption="Genel">
          <gbUserLanguage Caption="Kullanıcı Dili">
            <cxLanguageChoice Default="(varsayılan)"/>
            <pLanguagePreferred>
              <lbLanguagePreferred Caption="Tercih Edilen Dil:"/>
            </pLanguagePreferred>
            <lbLanguageSystem Caption="Sistem Dili: %s"/>
          </gbUserLanguage>
          <gbMiscellaneous Caption="Çeşitli">
            <cbShowHints Caption="Fare üzerine geldiğinde ipuçlarını göster."/>
            <cbColorButtons Caption="Renkli araç çubuğu düğmelerini kullan."/>
          </gbMiscellaneous>
          <gbOnlineUpdate Caption="Çevrimiçi Güncelleme">
            <cbAutoCheck Caption="Güncellemeleri otomatik olarak kontrol et"/>
            <pUpdateButton>
              <btnUpdateCheck Hint="En son güncelleme için çevrimiçi sunucuyu kontrol et." Caption="Şimdi kontrol et..."/>
            </pUpdateButton>
          </gbOnlineUpdate>
        </tsGeneral>
        <tsSession Hint="Uygulama oturumlarıyla ilgili seçenekler." Caption="Oturum">
          <gbSessionFiles Caption="Oturum dosyaları">
            <cbReopenFiles Hint="Önceki oturumdan kapatılmamış dosyaları yeniden aç." Caption="Önceki dosyaları yeniden aç."/>
            <cbWarnMissing Hint="Önceki oturumdan bir dosya mevcut olmadığında uyar." Caption="Eksik olduğunda uyar."/>
            <cbOpenExport Hint="Dışa aktarma dosyalarını inceleme için otomatik olarak aç." Caption="Dışa aktarılan dosyaları aç."/>
          </gbSessionFiles>
          <gbCodepage Caption="Kod Sayfası">
            <cbAutoSelectCP Hint="Dönüştürme için tercih edilen kod sayfasını otomatik olarak seç." Caption="Kod sayfasını otomatik seç"/>
          </gbCodepage>
        </tsSession>
		<tsTextEditor Hint="Metin düzenleyici seçenekleri." Caption="Metin Düzenleyici">
          <gbExternalEditor Caption="Harici Düzenleyici">
            <cbUseExternalEditor Hint="Basit yerleşik düzenleyici yerine harici bir metin düzenleyici kullanın." Caption="Harici bir metin düzenleyici kullan"/>
            <pEditor>
              <btnBrowseEditor Hint="Harici metin düzenleyiciye göz atın." Caption="Gözat"/>
            </pEditor>
            <BrowseDialog Caption="Harici metin düzenleyici tarayıcısı">
              <Title Caption="Harici metin düzenleyici tarayıcısı"/>
              <File>
                <Unix Exec="Tüm dosyalar|*"/>
                <Windows Exec="Yürütülebilir dosyalar|*.EXE|Tüm dosyalar|*.*"/>
              </File>
            </BrowseDialog>
          </gbExternalEditor>
        </tsTextEditor>
        <tsTextEditor Hint="Text editor options." Caption="Text Editor">
          <gbExternalEditor Caption="External Editor">
            <cbUseExternalEditor Hint="Use an external text editor instead of the simple built-in editor ." Caption="Use an external text editor"/>
            <pEditor>
              <btnBrowseEditor Hint="Browse for external text editor." Caption="Browse"/>
              <edExternalEditor Caption="bbedit"/>
            </pEditor>
            <BrowseDialog Caption="Browser for external text editor">
              <Title Caption="Browser for external text editor"/>
              <File>
                <Unix Exec="All files|*"/>
                <Windows Exec="Executable files|*.EXE|All files|*.*"/>
              </File>
            </BrowseDialog>
          </gbExternalEditor>
        </tsTextEditor>
        <tsEncoding Hint="Dosya girişi ve çıkışı kodlama seçenekleri." Caption="Kodlama">
          <rgFileEnding Hint="Dosyaların boş bir satırla bitmesini zorunlu tut." Caption="Dosyalar Yeni Satırla Biter">
            <rbFileEndWhatever Hint="Tüm dosyalar metin veya boş satırla bitebilir." Caption="Önemli değil."/>
            <rbFileEndExport Hint="Dışa aktarılan dosyaların boş bir satırla bittiğinden emin ol." Caption="Sadece Dışa Aktarma için sağla."/>
            <rbFileEndAll Hint="Orijinal dosyaların boş bir satırla bitmesini zorunlu tut." Caption="Tüm metin dosyalarında uygula."/>
          </rgFileEnding>
        </tsEncoding>
        <tsViewer Hint="Unicode ve DOS görüntüleyici seçenekleri." Caption="Görüntüleyici">
          <gbUnicodeView Caption="Unicode Görünümü">
            <lbUnicodeScale Caption="lbUnicodeScale"/>
            <tbUnicodeScale Caption="10"/>
            <lbScaleOfUnicode Caption="Yazı tipi ölçeği %%%s"/>
          </gbUnicodeView>
          <gbDOSView Caption="DOS Görünümü">
            <lbDOSScale Caption="lbDOSScale"/>
            <tbDOSScale Caption="1"/>
            <lbScaleOfDOS Caption="Yazı tipi ölçeği %%%s"/>
          </gbDOSView>
          <gbViewers Caption="Görüntüleyiciler">
            <cbSingleViewer Hint="Ana pencerede yalnızca tek bir dosya görünümü paneli göster." Caption="Tek dosya görüntüleyici modu"/>
          </gbViewers>
        </tsViewer>
      </pPages>
      <fLowerPanel>
        <fButtonPanel>
          <btnAccept Hint="Değişiklikleri kabul et ve uygula." Caption="Kabul Et"/>
          <btnCancel Hint="Tüm değişiklikleri yoksay." Caption="İptal"/>
        </fButtonPanel>
      </fLowerPanel>
      <fMiddlePanel>
        <fBodyPanel>
          <pSectionsPanel>
            <pSectionLabel>
