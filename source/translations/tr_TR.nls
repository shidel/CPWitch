    <fLoggerViewForm Caption="Hata ayıklama günlüğü">
      <LineCount Plural="%.0n günlük girişi" Singular="%.0n günlük girişi"/>
      <pControls>
        <pButtons>
          <btnClear Hint="Geçerli hata ayıklama günlüğünü temizle." Caption="Temizle"/>
          <btnSaveAs Hint="Hata ayıklama günlüğünü bir dosyaya kaydet." Caption="Farklı Kaydet..."/>
        </pButtons>
        <pVerbose>
          <cbVerbosity Hint="Hata ayıklama günlüğü mesajlarının ayrıntı düzeyini ve miktarını seçin. Lütfen bunun çok fazla bellek tüketebileceğini ve programı büyük ölçüde yavaşlatabileceğini unutmayın.">
            <Items Index_0="Kritik" Index_1="Minimal" Index_2="Normal" Index_3="Ayrıntılı" Index_4="Aşırı"/>
          </cbVerbosity>
          <lbVerbosity Caption="Ayrıntı Düzeyi:"/>
        </pVerbose>
      </pControls>
      <SaveAsDialog>
        <Title Caption="Hata ayıklama günlüğünü farklı kaydet"/>
        <File Filters="Günlük Dosyaları (*.log)|*.log|Tüm Dosyalar (*.*)|*.*"/>
      </SaveAsDialog>
    </fLoggerViewForm>
    <fDiffLocaleDialog Caption="Çakışan Yerel Ayar">
      <fLowerPanel>
        <fButtonPanel>
          <btnProceed Caption="Devam Et"/>
          <btnCancel Caption="İptal"/>
        </fButtonPanel>
      </fLowerPanel>
      <Message Text="Bu dosya için beklenen yerel ayar %s.&#xA;&#xA;Sözlüğe %s yerel ayarı altında eklemek istediğinizden emin misiniz?"/>
    </fDiffLocaleDialog>
    <fUpdateCheckDialog Caption="Güncelleme Kontrolü">
      <fLowerPanel>
        <fButtonPanel>
          <btnCancel Caption="İptal"/>
          <btnRetry Caption="Yeniden Dene"/>
        </fButtonPanel>
      </fLowerPanel>
      <Message>
        <Check Text="&quot;%s&quot; (sürüm %s) için mevcut güncellemeler kontrol ediliyor."/>
        <Error Text="Şu anda &quot;%s&quot; için herhangi bir güncelleme olup olmadığı belirlenemiyor. Lütfen daha sonra tekrar deneyin."/>
        <None Text="Şu anda &quot;%s&quot; için mevcut bir güncelleme yok. Lütfen daha sonra tekrar deneyin."/>
      </Message>
    </fUpdateCheckDialog>
    <fUpdateFoundDialog Caption="Güncelleme Mevcut">
      <fLowerPanel>
        <fButtonPanel>
          <btnCancel Caption="İptal"/>
          <btnDownload Caption="İndir"/>
          <btnSkip Caption="Atla"/>
        </fButtonPanel>
        <fAuxPanel>
          <cbSkipVersion Caption="Bu sürümü atla"/>
        </fAuxPanel>
      </fLowerPanel>
      <Message>
        <Note Text="&quot;%0:s&quot; uygulamasının %1:s sürümü için yayın notu sağlanmadı."/>
      </Message>
    </fUpdateFoundDialog>
    <fUpdateDownloadDialog Caption="Güncelleme İndirme">
      <fLowerPanel>
        <fButtonPanel>
          <btnCancel Caption="İptal"/>
          <btnRetry Caption="Yeniden Dene"/>
        </fButtonPanel>
      </fLowerPanel>
      <Message>
        <Fetch Text="&quot;%s&quot; güncellemesi indiriliyor."/>
        <Error Text="&quot;%s&quot; güncellemesi indirilirken hata oluştu. Lütfen daha sonra tekrar deneyin."/>
      </Message>
    </fUpdateDownloadDialog>
    <fUpdateSaveDialog Caption="Güncelleme İndirildi">
      <fLowerPanel>
        <fButtonPanel>
          <btnCancel Caption="İptal"/>
          <btnSaveAs Caption="Farklı kaydet..."/>
        </fButtonPanel>
      </fLowerPanel>
      <Message>
        <Downloaded Text="&quot;%s&quot; sürüm %s indirildi."/>
      </Message>
      <SaveAsDialog>
        <Title Caption="Güncellemeyi farklı kaydet"/>
        <File Filters="Arşiv Dosyaları (*.zip)|*.log|Tüm Dosyalar (*.*)|*.*"/>
      </SaveAsDialog>
    </fUpdateSaveDialog>
    <fCorrectFileEndingDialog Caption="Son satır sonu yok">
      <fLowerPanel>
        <fButtonPanel>
          <btnCorrect Caption="Düzelt"/>
          <btnIgnore Caption="Yoksay"/>
        </fButtonPanel>
      </fLowerPanel>
      <Message Text="&quot;%s&quot; dosyası boş bir satırla bitmiyor.&#xA;&#xA;Dosyanın sonuna yeni bir satır ekleyerek bunu düzeltmek ister misiniz?"/>
    </fCorrectFileEndingDialog>
    <fFileEditor Caption="Codepage Witch - %s">
      <btnCancel Caption="İptal"/>
      <btnSave Caption="Kaydet"/>
