<?xml version="1.0" encoding="utf-8"?>
<CONFIG Name="Português (Brasil)" Language="pt_BR">
  <Translation>
    <Revision_0 Date="2026-02-24" Contributor="Google Gemini"/>
  </Translation>
  <Application>
    <ModalButtons>
      <Ok Value="Ok"/>
      <Cancel Value="Cancelar"/>
      <Yes Value="Sim"/>
      <No Value="Não"/>
      <Close Value="Fechar"/>
      <Abort Value="Abortar"/>
      <Retry Value="Repetir"/>
      <Ignore Value="Ignorar"/>
      <All Value="Tudo"/>
      <NoToAll Value="Não para todos"/>
      <YesToAll Value="Sim para todos"/>
    </ModalButtons>
    <Error>
      <File>
        <Read>
          <Caption Value="Erro de leitura de arquivo"/>
          <Message Value="O erro #%1:s (%2:s) ocorreu ao ler o arquivo &quot;%0:s&quot;."/>
        </Read>
        <Write>
          <Caption Value="Erro de escrita de arquivo"/>
          <Message Value="O erro #%1:s (%2:s) ocorreu ao gravar no arquivo &quot;%0:s&quot;."/>
        </Write>
      </File>
      <Codes>
        <ecUnknown Value="Erro desconhecido."/>
        <ec0 Value="Sem erro"/>
        <ec2 Value="Arquivo não encontrado"/>
        <ec3 Value="Caminho não encontrado"/>
        <ec4 Value="Muitos arquivos abertos"/>
        <ec5 Value="Acesso negado"/>
        <ec6 Value="Alça de arquivo inválida"/>
        <ec12 Value="Modo de acesso inválido"/>
        <ec17 Value="Não é possível renomear entre dispositivos diferentes"/>
        <ec100 Value="Erro de leitura de disco"/>
        <ec101 Value="Erro de gravação de disco"/>
        <ec102 Value="Arquivo não atribuído"/>
        <ec103 Value="Arquivo não aberto"/>
        <ec104 Value="Arquivo não aberto para leitura"/>
        <ec105 Value="Arquivo não aberto para gravação"/>
        <ec106 Value="Formato numérico inválido"/>
        <ec150 Value="O disco está protegido contra gravação"/>
      </Codes>
    </Error>
    <FormatSettings>
      <CurrencyFormat Value="0"/>
      <NegCurrFormat Value="8"/>
      <DecimalSeparator Value=","/>
      <CurrencyDecimals Value="2"/>
      <DateSeparator Value="/"/>
      <TimeSeparator Value=":"/>
      <ListSeparator Value=";"/>
      <CurrencyString Value="R$"/>
      <ShortDateFormat Value="dd/mm/yyyy"/>
      <LongDateFormat Value="d 'de' mmmm 'de' yyyy"/>
      <TimeAMString Value=""/>
      <TimePMString Value=""/>
      <ShortTimeFormat Value="HH:mm"/>
      <LongTimeFormat Value="HH:mm:ss"/>
      <ShortMonthNames>
        <Index_1 Value="jan"/>
        <Index_2 Value="fev"/>
        <Index_3 Value="mar"/>
        <Index_4 Value="abr"/>
        <Index_5 Value="mai"/>
        <Index_6 Value="jun"/>
        <Index_7 Value="jul"/>
        <Index_8 Value="ago"/>
        <Index_9 Value="set"/>
        <Index_10 Value="out"/>
        <Index_11 Value="nov"/>
        <Index_12 Value="dez"/>
      </ShortMonthNames>
      <LongMonthNames>
        <Index_1 Value="janeiro"/>
        <Index_2 Value="fevereiro"/>
        <Index_3 Value="março"/>
        <Index_4 Value="abril"/>
        <Index_5 Value="maio"/>
        <Index_6 Value="junho"/>
        <Index_7 Value="julho"/>
        <Index_8 Value="agosto"/>
        <Index_9 Value="setembro"/>
        <Index_10 Value="outubro"/>
        <Index_11 Value="novembro"/>
        <Index_12 Value="dezembro"/>
      </LongMonthNames>
      <ShortDayNames>
        <Index_1 Value="dom"/>
        <Index_2 Value="seg"/>
        <Index_3 Value="ter"/>
        <Index_4 Value="qua"/>
        <Index_5 Value="qui"/>
        <Index_6 Value="sex"/>
        <Index_7 Value="sáb"/>
      </ShortDayNames>
      <LongDayNames>
        <Index_1 Value="domingo"/>
        <Index_2 Value="segunda-feira"/>
        <Index_3 Value="terça-feira"/>
        <Index_4 Value="quarta-feira"/>
        <Index_5 Value="quinta-feira"/>
        <Index_6 Value="sexta-feira"/>
        <Index_7 Value="sábado"/>
      </LongDayNames>
      <TwoDigitYearCenturyWindow Value="50"/>
    </FormatSettings>
  </Application>
  <Controls>
    <fMain Caption="Codepage Witch">
      <alMain>
        <actOpen Hint="Abrir um arquivo de texto." Caption="Abrir arquivo..."/>
        <actPreferences Hint="Exibir ou alterar as configurações do Codepage Witch." Caption="Preferências..."/>
        <actOnlineUpdate Hint="Procurar atualizações para o Codepage Witch." Caption="Atualização..."/>
        <actDebugLog Hint="Exibir o log de depuração." Caption="Log de depuração..."/>
        <actListAll Hint="Listar todas as codificações (codepages) conhecidas." Caption="Todas conhecidas"/>
        <actListPartial Hint="Listar todas as codificações possíveis." Caption="Qualquer possível"/>
        <actListCompatible Hint="Listar apenas codificações totalmente compatíveis." Caption="Apenas compatíveis"/>
        <actCodepageFilter Hint="Filtrar a lista de codificações." Caption="Filtro de Codificação"/>
        <actExportASCII Hint="Exportar arquivo como ASCII 7-bits (não requer codificação específica ou caracteres Unicode)." Caption="Exportar ASCII..."/>
        <actExportCodepage Hint="Exportar arquivo no formato de codificação." Caption="Exportar Codificação..."/>
        <actExportUnicode Hint="Exportar arquivo no formato UTF-8." Caption="Exportar UTF-8..."/>
        <actEditASCII Hint="Editar arquivo ASCII 7-bits simples." Caption="Editar ASCII..."/>
        <actEditCodepage Hint="Editar arquivo com codificação específica." Caption="Editar Codificação..."/>
        <actEditUnicode Hint="Editar arquivo de texto Unicode." Caption="Editar Unicode..."/>
        <actExportNone Hint="Este tipo de arquivo não pode ser exportado." Caption="Sem exportação"/>
        <actClose Hint="Fechar o arquivo de texto atual." Caption="Fechar arquivo"/>
        <actCloseAll Hint="Fechar todos os arquivos de texto abertos." Caption="Fechar tudo"/>
        <actEditNone Hint="Este tipo de arquivo não possui editor." Caption="Sem editor"/>
        <actDictionary Hint="Open user dictionary editor." Caption="actDictionary"/>
      </alMain>
      <pBody>
        <pFileList>
          <pFileListLabel>
            <lbFileList Caption="Text Files"/>
          </pFileListLabel>
        </pFileList>
        <pCodepageList>
          <pCodepageListLabel>
            <lbCodepageLabel Caption="Codepages"/>
          </pCodepageListLabel>
          <lvCodepageList>
            <Analyzing Caption="Analyzing"/>
            <Not_implemented Caption="Not implemented"/>
            <Any_Codepage Caption="Any Codepage"/>
            <Binary_data Caption="Binary File"/>
          </lvCodepageList>
        </pCodepageList>
        <pViewers>
          <pViewUnicode>
            <pViewUnicodeLabel>
              <lbUnicodeViewLabel Caption="Viewed as Unicode"/>
            </pViewUnicodeLabel>
            <Unsupported_file>
              <Binary Text="Binary data files are not supported."/>
            </Unsupported_file>
          </pViewUnicode>
          <pCodepage>
            <pViewCodepageLabel>
              <lbViewCodepageLabel Value="Viewed as Codepage %s"/>
            </pViewCodepageLabel>
          </pCodepage>
        </pViewers>
      </pBody>
      <Locales>
        <ar_SA Text="Árabe (Arábia Saudita)"/>
        <cs_CZ Text="Tcheco (Tchéquia)"/>
        <da_DK Text="Dinamarquês (Dinamarca)"/>
        <de_CH Text="Alemão (Suíça)"/>
        <de_DE Text="Alemão (Alemanha)"/>
        <en_US Text="Inglês (Estados Unidos)"/>
        <eo Text="Esperanto"/>
        <es_ES Text="Espanhol (Espanha)"/>
        <et_EE Text="Estoniano (Estônia)"/>
        <fi_FI Text="Finlandês (Finlândia)"/>
        <fr_CA Text="Francês (Canadá)"/>
        <fr_FR Text="Francês (França)"/>
        <he_IL Text="Hebraico (Israel)"/>
        <hu_HU Text="Húngaro (Hungria)"/>
        <is_IS Text="Islandês (Islândia)"/>
        <it_IT Text="Italiano (Itália)"/>
        <ja_JP Text="Japonês (Japão)"/>
        <lt_LT Text="Lituano (Lituânia)"/>
        <la Text="Latim"/>
        <lv_LV Text="Letão (Letônia)"/>
        <nl_NL Text="Holandês (Países Baixos)"/>
        <no_NO Text="Norueguês (Noruega)"/>
        <pl_PL Text="Polonês (Polônia)"/>
        <pl_MAZ Text="Polonês (Mazoviano)"/>
        <pt_BR Text="Português (Brasil)"/>
        <pt_PT Text="Português (Portugal)"/>
        <ru_RU Text="Russo (Rússia)"/>
        <sk_SK Text="Eslovaco (Eslováquia)"/>
        <sl_SI Text="Esloveno (Eslovênia)"/>
        <sr_RS Text="Sérvio (Sérvia)"/>
        <zh_CN Text="Chinês (Simplificado)"/>
        <sv_SE Text="Sueco (Suécia)"/>
        <tr_TR Text="Turco (Turquia)"/>
        <uk_UA Text="Ucraniano (Ucrânia)"/>
        <bg_BG Text="Búlgaro (Bulgária)"/>
        <el_GR Text="Grego (Grécia)"/>
        <fil_PH Text="Filipino (Filipinas)"/>
        <tl_PH Text="Tagalo (Filipinas)"/>
        <haw_US Text="Havaiano (Estados Unidos)"/>
        <id_ID Text="Indonésio (Indonésia)"/>
        <ko_KR Text="Coreano (Coreia do Sul)"/>
        <nb_NO Text="Norueguês Bokmål (Noruega)"/>
        <nn_NO Text="Norueguês Nynorsk (Noruega)"/>
        <ro_RO Text="Romeno (Romênia)"/>
        <sm_WS Text="Samoano (Samoa)"/>
        <th_TH Text="Tailandês (Tailândia)"/>
        <vi_VN Text="Vietnamita (Vietnã)"/>
      </Locales>
      <statBar>
        <Processing Caption="Processando"/>
        <LineEnding CR="CR" LF="LF" CRLF="CRLF"/>
        <Codepage Caption="Codificação"/>
        <Unicode Caption="Unicode"/>
        <NoEncoding Caption="ASCII"/>
        <Binary Caption="Binário"/>
      </statBar>
      <OpenFilesDialog>
        <Title Caption="Open existing file(s)"/>
        <File Filters="All Files (*.*)|*.*|Unicode Files (*.UTF-8)|*.UTF-8"/>
      </OpenFilesDialog>
      <ExportCodepageDialog>
        <Title Caption="Export file as Codepage %s"/>
        <File Filters="All Files (*.*)|*.*"/>
      </ExportCodepageDialog>
      <ExportASCIIDialog>
        <Title Caption="Save file as simple 7-bit ASCII"/>
        <File Filters="All Files (*.*)|*.*"/>
      </ExportASCIIDialog>
      <OpenFiles>
        <Title Caption="Open existing file(s)"/>
        <File Filters="All Files|*;*.*"/>
      </OpenFiles>
      <pFileList>
        <pFileListLabel>
          <lbFileList Caption="Arquivos de Texto"/>
        </pFileListLabel>
      </pFileList>
      <pCodepageList>
        <pCodepageListLabel>
          <lbCodepageLabel Caption="Codificações"/>
        </pCodepageListLabel>
        <lvCodepageList>
          <Analyzing Caption="Analisando"/>
          <Any_Codepage Caption="Qualquer codificação"/>
          <Not_implemented Caption="Não implementado"/>
          <Binary_data Caption="Dados binários"/>
        </lvCodepageList>
      </pCodepageList>
      <pViewers>
        <pViewUnicode>
          <pViewUnicodeLabel>
            <lbUnicodeViewLabel Caption="Exibido como Unicode"/>
          </pViewUnicodeLabel>
          <Unsupported_file>
            <Binary Text="Arquivos de dados binários não são suportados."/>
          </Unsupported_file>
        </pViewUnicode>
        <pCodepage>
          <pViewCodepageLabel>
            <lbViewCodepageLabel Value="Exibido como codificação %s"/>
          </pViewCodepageLabel>
        </pCodepage>
      </pViewers>
    </fMain>
    <fDictEditForm Caption="Atualizador de Dicionário">
      <pTop>
        <cbLocale Hint="Locale for the words to add to the dictionary.">
          <Items Index_0="ar_SA" Index_1="bg_BG" Index_2="cs_CZ" Index_3="da_DK" Index_4="de_CH" Index_5="de_DE" Index_6="el_GR" Index_7="en_US" Index_8="eo" Index_9="es_ES" Index_10="et_EE" Index_11="fil_PH" Index_12="fi_FI" Index_13="fr_FR" Index_14="haw_US" Index_15="he_IL" Index_16="hu_HU" Index_17="id_ID" Index_18="is_IS" Index_19="it_IT" Index_20="ja_JP" Index_21="ko_KR" Index_22="la" Index_23="lt_LT" Index_24="lv_LV" Index_25="nb_NO" Index_26="nl_NL" Index_27="no_NO" Index_28="pl_MAZ" Index_29="pl_PL" Index_30="pt_BR" Index_31="pt_PT" Index_32="ro_RO" Index_33="ru_RU" Index_34="sk_SK" Index_35="sl_SI" Index_36="sm_WS" Index_37="sr_RS" Index_38="sv_SE" Index_39="th_TH" Index_40="tr_TR" Index_41="uk_UA" Index_42="vi_VN" Index_43="zh_CN" Index_44="fr_CA" Index_45="tl_PH" Index_46="nn_NO"/>
        </cbLocale>
        <lbLocale Hint="Select the Locale for the words to add to the dictionary." Caption="Localidade:"/>
        <btnInvert Hint="Toggle all slecetions." Caption="Inverter"/>
        <btnNone Hint="Unselect all words." Caption="Nenhum"/>
      </pTop>
      <pButtons>
        <btnSave Hint="Save the changes to the dictionary." Caption="Salvar"/>
        <btnReload Hint="Reload the dinctionary and forget any unsaved changes." Caption="Recarregar"/>
        <btnAdd Hint="Add the selected words to the dictionary for the selected locale." Caption="Adicionar ao Dicionário"/>
        <btnMerge Hint="Merge the User dictionary words into the Master dictionary." Caption="Merge"/>
      </pButtons>
    </fDictEditForm>
    <fOptionsDialog Caption="Configurações do Codepage Witch">
      <pPages>
        <tsAbout Hint="Sobre este aplicativo." Caption="Sobre">
          <lbCopyright Caption="Copyright %s"/>
          <lbVersion Caption="Versão %0:s (Build %1:s)"/>
          <lbApplication Caption="O &quot;%s&quot;"/>
        </tsAbout>
        <tsGeneral Hint="Configurações gerais do aplicativo." Caption="Geral">
          <gbUserLanguage Caption="Idioma do Usuário">
            <cxLanguageChoice Default="(padrão)"/>
            <pLanguagePreferred>
              <lbLanguagePreferred Caption="Idioma preferido:"/>
            </pLanguagePreferred>
            <lbLanguageSystem Caption="Idioma do sistema: %s"/>
          </gbUserLanguage>
          <gbMiscellaneous Caption="Diversos">
            <cbShowHints Caption="Mostrar dicas ao passar o mouse."/>
            <cbColorButtons Caption="Usar ícones coloridos na barra de ferramentas."/>
          </gbMiscellaneous>
          <gbOnlineUpdate Caption="Atualização Online">
            <cbAutoCheck Caption="Procurar atualizações automaticamente"/>
            <pUpdateButton>
              <btnUpdateCheck Hint="Consultar o servidor para procurar a atualização mais recente." Caption="Verificar agora..."/>
            </pUpdateButton>
          </gbOnlineUpdate>
        </tsGeneral>
        <tsSession Hint="Opções relacionadas às sessões do aplicativo." Caption="Sessão">
          <gbSessionFiles Caption="Arquivos de Sessão">
            <cbReopenFiles Hint="Reabrir arquivos que não foram fechados na sessão anterior." Caption="Reabrir arquivos anteriores."/>
            <cbWarnMissing Hint="Avisar se um arquivo da sessão anterior não existir." Caption="Avisar se faltar."/>
            <cbOpenExport Hint="Abrir automaticamente arquivos exportados para revisão." Caption="Abrir arquivos exportados."/>
          </gbSessionFiles>
          <gbCodepage Caption="Página de Código">
            <cbAutoSelectCP Hint="Selecionar automaticamente a página de código preferida para conversão." Caption="Selecionar página de código automaticamente"/>
          </gbCodepage>
        </tsSession>
        <tsEncoding Hint="Opções de codificação de entrada e saída de arquivos." Caption="Codificação">
          <rgFileEnding Hint="Exigir que os arquivos terminem com uma linha em branco." Caption="Arquivos terminam com nova linha">
            <rbFileEndWhatever Hint="Arquivos podem terminar com texto ou uma linha em branco." Caption="Tanto faz."/>
            <rbFileEndExport Hint="Garantir que arquivos exportados terminem com uma linha em branco." Caption="Garantir apenas na exportação."/>
            <rbFileEndAll Hint="Exigir que arquivos originais terminem com uma linha em branco." Caption="Aplicar a todos os arquivos de texto."/>
          </rgFileEnding>
        </tsEncoding>
        <tsViewer Hint="Opções para os visualizadores Unicode e DOS." Caption="Visualizador">
          <gbUnicodeView Caption="Visualização Unicode">
            <lbUnicodeScale Caption="Escala da fonte %s%%"/>
            <tbUnicodeScale Caption="10"/>
          </gbUnicodeView>
          <gbDOSView Caption="Visualização DOS">
            <lbDOSScale Caption="Escala da fonte %s%%"/>
            <tbDOSScale Caption="1"/>
          </gbDOSView>
        </tsViewer>
      </pPages>
      <fLowerPanel>
        <fButtonPanel>
          <btnAccept Hint="Aceitar e aplicar todas as alterações." Caption="Aceitar"/>
          <btnCancel Hint="Ignorar todas as alterações." Caption="Cancelar"/>
        </fButtonPanel>
      </fLowerPanel>
      <fMiddlePanel>
        <fBodyPanel>
          <pSectionsPanel>
            <pSectionLabel>
              <lbSections Caption="Opções"/>
            </pSectionLabel>
          </pSectionsPanel>
          <pPagesPanel>
            <pPages>
              <tsViewer>
                <lbUnicodeScale Caption="Escala da fonte %s%%"/>
                <lbDOSScale Caption="Escala da fonte %s%%"/>
              </tsViewer>
            </pPages>
          </pPagesPanel>
        </fBodyPanel>
      </fMiddlePanel>
    </fOptionsDialog>
    <fUpdateCheckDialog Caption="Procurar Atualização">
      <fLowerPanel>
        <fButtonPanel>
          <btnCancel Caption="Cancelar"/>
          <btnRetry Caption="Repetir"/>
        </fButtonPanel>
      </fLowerPanel>
      <Message>
        <Check Text="Procurando atualizações para &quot;%s&quot;, versão %s."/>
        <Error Text="No momento não é possível determinar se existem atualizações para &quot;%s&quot;. Tente novamente mais tarde."/>
        <None Text="Não existem atualizações para &quot;%s&quot; no momento. Verifique mais tarde."/>
      </Message>
    </fUpdateCheckDialog>
    <fUpdateFoundDialog Caption="Atualização Disponível">
      <fLowerPanel>
        <fButtonPanel>
          <btnCancel Caption="Cancelar"/>
          <btnDownload Caption="Baixar"/>
          <btnSkip Caption="Pular"/>
        </fButtonPanel>
        <fAuxPanel>
          <cbSkipVersion Caption="Pular esta versão"/>
        </fAuxPanel>
      </fLowerPanel>
      <Message>
        <Note Text="Não foram fornecidas notas de lançamento para a versão %1:s de &quot;%0:s&quot;."/>
      </Message>
    </fUpdateFoundDialog>
    <fUpdateDownloadDialog Caption="Baixar Atualização">
      <fLowerPanel>
        <fButtonPanel>
          <btnCancel Caption="Cancelar"/>
          <btnRetry Caption="Repetir"/>
        </fButtonPanel>
      </fLowerPanel>
      <Message>
        <Fetch Text="Baixando atualização para &quot;%s&quot;."/>
        <Error Text="Erro ao baixar a atualização de &quot;%s&quot;. Tente novamente mais tarde."/>
      </Message>
    </fUpdateDownloadDialog>
    <fUpdateSaveDialog Caption="Atualização Baixada">
      <fLowerPanel>
        <fButtonPanel>
          <btnCancel Caption="Cancelar"/>
          <btnSaveAs Caption="Salvar como..."/>
        </fButtonPanel>
      </fLowerPanel>
      <Message>
        <Downloaded Text="Baixada a versão %s de &quot;%s&quot;."/>
      </Message>
      <SaveAsDialog>
        <Title Caption="Save update as"/>
        <File Filters="Archive Files (*.zip)|*.log|All Files (*.*)|*.*"/>
      </SaveAsDialog>
    </fUpdateSaveDialog>
    <fLoggerViewForm Title="Save debug log as" Filter="Log Files (*.log)|All Files (*.*)" Caption="Log de Depuração">
      <LineCount Plural="%.0n entradas de log" Singular="%.0n entrada de log"/>
      <pControls>
        <pButtons>
          <btnClear Hint="Clear the current debug log." Caption="Limpar"/>
          <btnSaveAs Hint="Save the debug log to a file." Caption="Salvar como..."/>
        </pButtons>
        <pVerbose>
          <cbVerbosity Hint="Select the verbosity and amount of debug logging messages. Please note this can consume a lot of memory and slow the program drastically.">
            <Items Index_0="Crítico" Index_1="Mínimo" Index_2="Normal" Index_3="Detalhado" Index_4="Excessivo"/>
          </cbVerbosity>
          <lbVerbosity Caption="Detalhamento:"/>
        </pVerbose>
      </pControls>
      <SaveDialog>
        <Title Caption="Save debug log as"/>
        <File Filters="Log Files (*.log)|*.log|All Files (*.*)|*.*"/>
      </SaveDialog>
      <Title SaveDialog="Save debug log as"/>
      <Filter SaveDialog="Log Files (*.log)|*.log|All Files (*.*)|*.*"/>
    </fLoggerViewForm>
    <fCorrectFileEndingDialog Caption="Falta quebra de linha final">
      <fLowerPanel>
        <fButtonPanel>
          <btnCorrect Caption="Corrigir"/>
          <btnIgnore Caption="Ignorar"/>
        </fButtonPanel>
      </fLowerPanel>
      <Message Text="O arquivo &quot;%s&quot; não termina com uma linha em branco.&#xA;&#xA;Deseja corrigir adicionando uma quebra de linha ao fim do arquivo?"/>
    </fCorrectFileEndingDialog>
    <fFileEditor Caption="Codepage Witch - %s">
      <btnCancel Caption="Cancelar"/>
      <btnSave Caption="Salvar"/>
      <dlgSaveAs Title="Erro ao salvar arquivo, salvar como"/>
    </fFileEditor>
    <fMissingFiles Caption="Arquivos de Documentos Ausentes">
      <fLowerPanel>
        <fButtonPanel>
          <btnCancel Caption="Cancelar"/>
        </fButtonPanel>
      </fLowerPanel>
    </fMissingFiles>
  </Controls>
</CONFIG>
